generator client {
  provider    = "prisma-client"
  output      = "../src/generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  createdAt    DateTime      @default(now())
  profile      Profile?
  generatedCvs GeneratedCv[]
}

model Profile {
  id          String           @id @default(uuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  title       String?
  summary     String?
  location    String?
  linkedinUrl String?
  githubUrl   String?
  experiences WorkExperience[]
  skills      Skill[]
  educations  Education[]
}

model WorkExperience {
  id           String    @id @default(uuid())
  profileId    String
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company      String
  position     String
  startDate    DateTime
  endDate      DateTime?
  description  String
  technologies String[]
}

model Skill {
  id        String  @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  level     Int?
}

model Education {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  startDate   DateTime
  endDate     DateTime?
}

model GeneratedCv {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCompany  String
  targetRole     String
  jobDescription String
  cvContentJson  Json
  templateName   String
  pdfUrl         String?
  createdAt      DateTime @default(now())
}